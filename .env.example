OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini

# Ollama (local) — LiteLLM route prefix ollama/<model>. Pull first:
#   ollama pull qwen2.5-coder:14b && ollama pull deepseek-coder:16b
OLLAMA_API_BASE=http://localhost:11434

# LiteLLM model routes (provider/model). CrewAI calls LiteLLM under the hood.
# Defaults in code match this Ollama split; unset these to use code defaults.
MODEL_PLANNING=ollama/qwen2.5-coder:14b
MODEL_IMPACT=ollama/qwen2.5-coder:14b
MODEL_DOC=ollama/qwen2.5-coder:14b
MODEL_BINDING=ollama/deepseek-coder:16b
MODEL_CODING=ollama/deepseek-coder:16b
MODEL_FIXING=ollama/deepseek-coder:16b
MODEL_TESTING=ollama/qwen2.5-coder:14b
MODEL_DEFAULT=ollama/qwen2.5-coder:14b
# Optional: dedicated tool-calling model for agents that use tools
# MODEL_FUNCTION_CALLING=ollama/qwen2.5-coder:14b

# For cloud models instead, use e.g. anthropic/claude-… or openai/gpt-4o and set keys below.
# Anthropic orgs with low input TPM (e.g. 30k/min on Sonnet): use a smaller model for planning,
# or set DIN_AGENTS_COMPACT_PROMPTS=1 below; one large crew prompt can exceed TPM in a single call.
# Use a versioned model id (Anthropic does not accept *-latest on the API). Haiku example:
#   MODEL_PLANNING=anthropic/claude-haiku-4-5-20251001
#   MODEL_IMPACT=anthropic/claude-haiku-4-5-20251001
# (Older ids like claude-3-5-haiku-20241022 may return not_found from the API.)
# Anthropic (only if you use Claude routes in MODEL_*)
ANTHROPIC_API_KEY=

# Smaller task text + truncated entry_points/hard_boundaries injected into each crew task (~saves input tokens).
# DIN_AGENTS_COMPACT_PROMPTS=1

# Cap how much prior sequential task output is pasted into later tasks (default 18000 chars).
# Large first-task briefs + tool logs can exceed per-request input TPM; lower this (e.g. 12000) if needed.
# Set to 0 to disable truncation (full prior context).
# DIN_AGENTS_MAX_TASK_CONTEXT_CHARS=18000

# Cap UTF-8 characters per read_*_repo_file tool result (default 20000). Huge sources (e.g. patch models)
# blow past Anthropic input TPM when several reads stack in one agent turn; lower to ~12000 if needed.
# DIN_AGENTS_MAX_REPO_READ_TOOL_CHARS=20000

# Seconds to sleep before each crew kickoff (after routing). Use 45–90 if you still hit TPM at crew start.
# DIN_AGENTS_PRE_CREW_SLEEP_S=60

DIN_CORE_PATH=/Users/veacks/Sites/din-core
REACT_DIN_PATH=/Users/veacks/Sites/react-din
DIN_STUDIO_PATH=/Users/veacks/Sites/din-studio

# CrewAI agents can call scoped file-write tools (relative paths only, under the paths above).
# Set to 0/false/no to block all repo writes from tools (planning-only).
# DIN_AGENTS_REPO_WRITE=1

# Optional defaults for `crewai run`
DIN_AGENTS_REQUEST=Assess a cross-repo patch contract change touching din-core and react-din.
DIN_AGENTS_REPO_HINT=
# CLI ergonomics: `uv run run_request -q` or set to 1 for less CrewAI terminal noise
# DIN_AGENTS_QUIET=1
# DIN_AGENTS_REPORT_PATH=output/control-plane-report.md
# Skip stdout copy of the report (file still written): DIN_AGENTS_NO_PRINT=1

# Provider rate limits — after RateLimitError the flow retries with backoff.
# Input "tokens per minute" (Anthropic TPM): first retry defaults to 120s. Override if needed:
# DIN_AGENTS_TPM_BACKOFF_BASE_S=180
# DIN_AGENTS_RATE_LIMIT_BACKOFF_INITIAL_S=30
# DIN_AGENTS_RATE_LIMIT_MAX_RETRIES=6
