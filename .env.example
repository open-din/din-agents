OPENAI_API_KEY=
OPENAI_MODEL_NAME=gpt-4o-mini

# LiteLLM model routes (provider/model). CrewAI calls LiteLLM under the hood.
# Claude roles: planning, impact, documentation
MODEL_PLANNING=anthropic/claude-3-5-sonnet-20241022
MODEL_IMPACT=anthropic/claude-3-5-sonnet-20241022
MODEL_DOC=anthropic/claude-3-5-sonnet-20241022
# Codex-style / OpenAI roles: binding, coding, fixing (adjust to your OpenAI model names)
MODEL_BINDING=openai/gpt-4o
MODEL_CODING=openai/gpt-4o
MODEL_FIXING=openai/gpt-4o
# Cheap validation / tester role
MODEL_TESTING=openai/gpt-4o-mini
MODEL_DEFAULT=openai/gpt-4o-mini
# Optional: dedicated tool-calling model for agents that use tools
# MODEL_FUNCTION_CALLING=openai/gpt-4o-mini

# Anthropic (if using Claude models above)
ANTHROPIC_API_KEY=

DIN_CORE_PATH=/Users/veacks/Sites/din-core
REACT_DIN_PATH=/Users/veacks/Sites/react-din
DIN_STUDIO_PATH=/Users/veacks/Sites/din-studio

# Optional defaults for `crewai run`
DIN_AGENTS_REQUEST=Assess a cross-repo patch contract change touching din-core and react-din.
DIN_AGENTS_REPO_HINT=
